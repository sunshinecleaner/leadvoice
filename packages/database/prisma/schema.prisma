generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  AGENT
}

// ─── Leads ────────────────────────────────────────────────────────────────────

enum LeadSource {
  CSV
  API
  CRM
  LANDING_PAGE
  MANUAL
  INBOUND_CALL
  OUTBOUND_CALL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum CrmStage {
  LEAD_NEW
  LEAD_NO_PHONE
  LEAD_QUALIFIED
  CHECKLIST_SENT
  SCHEDULED
  IN_PROGRESS
  SERVICE_COMPLETED
  PAYMENT_PENDING
  PAID
  UPSELL
  REFERRAL_REQUESTED
}

enum Language {
  EN
  ES
}

enum PropertyType {
  HOUSE
  APARTMENT
  CONDO
  OFFICE
  OTHER
}

enum ConditionLevel {
  LIGHT
  MODERATE
  HEAVY
}

// ─── Services ─────────────────────────────────────────────────────────────────

enum ServiceType {
  STANDARD_CLEANING
  DEEP_CLEANING
  RECURRING
  MOVE_IN
  MOVE_OUT
  POST_CONSTRUCTION
}

enum ServiceFrequency {
  ONE_TIME
  WEEKLY
  BI_WEEKLY
  MONTHLY
}

enum PaymentMethod {
  ZELLE
  VENMO
  CASH_APP
  PAYPAL
  CASH
}

enum PaymentStatus {
  PENDING
  DEPOSIT_PAID
  PAID
  PARTIAL
  REFUNDED
}

// ─── Campaigns ────────────────────────────────────────────────────────────────

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum CampaignLeadStatus {
  PENDING
  CALLING
  COMPLETED
  FAILED
  SKIPPED
}

// ─── Calls ────────────────────────────────────────────────────────────────────

enum CallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  NO_ANSWER
  BUSY
  TRANSFERRED
}

enum CallDirection {
  OUTBOUND
  INBOUND
}

enum CallOutcome {
  INTERESTED
  NOT_INTERESTED
  CALLBACK
  TRANSFERRED
  VOICEMAIL
  SCHEDULED
  DEPOSIT_REQUESTED
  ERROR
}

// ─── Integrations ─────────────────────────────────────────────────────────────

enum IntegrationType {
  HUBSPOT
  SALESFORCE
  WEBHOOK
  ZAPIER
  GOOGLE_SHEETS
  N8N
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(AGENT)
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedLeads    Lead[]
  createdCampaigns Campaign[]
  handledCalls     Call[]     @relation("AgentCalls")

  @@map("users")
}

model Lead {
  id        String     @id @default(cuid())
  firstName String
  lastName  String
  phone     String
  email     String?
  company   String?
  source    LeadSource @default(MANUAL)
  status    LeadStatus @default(NEW)
  crmStage  CrmStage   @default(LEAD_NEW)
  language  Language   @default(EN)
  score     Int        @default(0)
  timezone  String?
  tags      String[]   @default([])
  notes     String?
  metadata  Json?

  // Property details
  address      String?
  city         String?
  state        String?
  zipCode      String?
  propertyType PropertyType?
  bedrooms     Int?
  bathrooms    Int?
  sqft         Int?
  isOccupied   Boolean?

  // Service qualification
  conditionLevel     ConditionLevel?
  preferredSchedule  String?

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaignLeads   CampaignLead[]
  calls           Call[]
  serviceRequests ServiceRequest[]

  @@index([status])
  @@index([crmStage])
  @@index([source])
  @@index([phone])
  @@index([email])
  @@map("leads")
}

model ServiceRequest {
  id        String      @id @default(cuid())
  leadId    String
  lead      Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  serviceType    ServiceType
  frequency      ServiceFrequency @default(ONE_TIME)
  addOns         String[]         @default([])
  checklistSent  Boolean          @default(false)
  scheduledDate  DateTime?
  notes          String?          @db.Text

  // Pricing
  estimatedAmount Float?
  totalAmount     Float?
  depositRequired Boolean       @default(false)
  depositAmount   Float?
  depositPaid     Boolean       @default(false)

  // Payment
  paymentMethod PaymentMethod?
  paymentStatus PaymentStatus  @default(PENDING)
  paidAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([serviceType])
  @@index([paymentStatus])
  @@map("service_requests")
}

model Campaign {
  id                 String         @id @default(cuid())
  name               String
  description        String?
  status             CampaignStatus @default(DRAFT)
  script             String         @db.Text
  voiceId            String?
  maxRetries         Int            @default(3)
  retryDelayMinutes  Int            @default(60)
  callingWindowStart String         @default("09:00")
  callingWindowEnd   String         @default("17:00")
  timezone           String         @default("America/New_York")

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaignLeads CampaignLead[]

  @@map("campaigns")
}

model CampaignLead {
  id            String             @id @default(cuid())
  campaignId    String
  campaign      Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId        String
  lead          Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status        CampaignLeadStatus @default(PENDING)
  attempts      Int                @default(0)
  lastAttemptAt DateTime?
  scheduledAt   DateTime?

  calls Call[]

  @@unique([campaignId, leadId])
  @@index([status])
  @@map("campaign_leads")
}

model Call {
  id             String        @id @default(cuid())
  campaignLeadId String?
  campaignLead   CampaignLead? @relation(fields: [campaignLeadId], references: [id], onDelete: SetNull)
  leadId         String
  lead           Lead          @relation(fields: [leadId], references: [id])
  vapiCallId     String?       @unique
  twilioCallSid  String?       @unique
  status         CallStatus    @default(INITIATED)
  direction      CallDirection @default(OUTBOUND)
  duration       Int?
  recordingUrl   String?
  transcription  String?       @db.Text
  summary        String?       @db.Text
  outcome        CallOutcome?
  agentId        String?
  agent          User?         @relation("AgentCalls", fields: [agentId], references: [id], onDelete: SetNull)
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime      @default(now())

  events CallEvent[]

  @@index([status])
  @@index([leadId])
  @@index([vapiCallId])
  @@index([twilioCallSid])
  @@map("calls")
}

model CallEvent {
  id        String   @id @default(cuid())
  callId    String
  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  event     String
  data      Json?
  timestamp DateTime @default(now())

  @@index([callId])
  @@map("call_events")
}

model Integration {
  id        String          @id @default(cuid())
  type      IntegrationType
  name      String
  config    Json
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("integrations")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("string")

  @@map("settings")
}
